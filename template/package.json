{
  "name": "my-tg-cloudflare-bot",
  "version": "0.1.0",
  "description": "A Telegram bot built with grammY, deployed as a Cloudflare Worker.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "keywords": [],
  "license": "ISC",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p test/tsconfig.json",
    "dev": "node scripts/dev.mjs",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@types/node": "^22.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "grammy": "^1.44.0"
  }
}
